apiVersion: helm.cattle.io/v1
kind: HelmChartConfig
metadata:
  name: rke2-ingress-nginx
  namespace: kube-system
spec:
  valuesContent: |-
    controller:
      ingressClassResource:
        name: nginx
        enabled: true
        default: true
        controllerValue: k8s.io/ingress-nginx
      hostPort:
        enabled: false
      service:
        enabled: true
        type: LoadBalancer
        loadBalancerIP: 192.168.28.25
        annotations:
          metallb.universe.tf/address-pool: first-pool
      admissionWebhooks:
        enabled: true
