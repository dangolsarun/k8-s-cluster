apiVersion: helm.cattle.io/v1
kind: HelmChartConfig
metadata:
  name: rke2-ingress-nginx
  namespace: kube-system
spec:
  valuesContent: |-
    controller:
      extraArgs:
        default-ssl-certificate: "kube-system/dishhome-wildcard-tls"
      service:
        enabled: true
        type: LoadBalancer
        loadBalancerIP: 192.168.28.126
      publishService:
        enabled: true
